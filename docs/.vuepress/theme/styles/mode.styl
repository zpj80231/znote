:root
  --default-color-10 $lightColor10
  --default-color-9 $lightColor9
  --default-color-8 $lightColor8
  --default-color-7 $lightColor7
  --default-color-6 $lightColor6
  --default-color-5 $lightColor5
  --default-color-4 $lightColor4
  --default-color-3 $lightColor3
  --default-color-2 $lightColor2
  --default-color-1 $lightColor1
  --background-color $backgroundColor
  --box-shadow $boxShadow
  --box-shadow-hover $boxShadowHover
  --text-color $textColor
  --border-color $borderColor
  --code-color $codeColor
  --code-block-bg #f8fafc
  --code-block-color #334155
  --code-line-highlight rgba(14, 116, 144, 0.10)
  --code-line-highlight-border rgba(14, 116, 144, 0.55)
  --code-line-number-bg rgba(15, 23, 42, 0.035)
  --code-line-number-color rgba(51, 65, 85, 0.42)
  --code-lang-color rgba(51, 65, 85, 0.48)
  --code-divider-color rgba(15, 23, 42, 0.10)
  --code-token-comment #64748b
  --code-token-punctuation #64748b
  --code-token-keyword #0f766e
  --code-token-function #2563eb
  --code-token-string #047857
  --code-token-number #b45309
  --code-token-class #7c3aed
  --code-token-operator #475569
  --mask-color $maskColor
  @media (prefers-color-scheme: dark)
    --default-color-10 $darkColor10
    --default-color-9 $darkColor9
    --default-color-8 $darkColor8
    --default-color-7 $darkColor7
    --default-color-6 $darkColor6
    --default-color-5 $darkColor5
    --default-color-4 $darkColor4
    --default-color-3 $darkColor3
    --default-color-2 $darkColor2
    --default-color-1 $darkColor1
    --background-color $backgroundColorDark
    --box-shadow $boxShadowDark
    --box-shadow-hover $boxShadowHoverDark
    --text-color $textColorDark
    --border-color $borderColorDark
    --code-color $codeColorDark
    --code-block-bg #161b22
    --code-block-color #e6edf3
    --code-line-highlight rgba(251, 191, 36, 0.18)
    --code-line-highlight-border rgba(251, 191, 36, 0.82)
    --code-line-number-bg rgba(255, 255, 255, 0.055)
    --code-line-number-color rgba(230, 237, 243, 0.44)
    --code-lang-color rgba(230, 237, 243, 0.5)
    --code-divider-color rgba(255, 255, 255, 0.1)
    --code-token-comment #8b949e
    --code-token-punctuation #c9d1d9
    --code-token-keyword #ff7b72
    --code-token-function #d2a8ff
    --code-token-string #a5d6ff
    --code-token-number #79c0ff
    --code-token-class #ffa657
    --code-token-operator #c9d1d9
    --mask-color $maskColorDark
