.content__default
  code
    color var(--text-color)
    padding 0.25rem 0.5rem
    margin 0
    font-size 0.85em
    background-color var(--code-color)
    border-radius 3px
    .token
      &.deleted
        color #EC5975
      &.inserted
        color $accentColor

.content__default
  pre, pre[class*="language-"]
    line-height 1.4
    padding 1.25rem 1.5rem
    margin 0.85rem 0
    background-color var(--code-block-bg)
    border-radius 6px
    overflow auto
    code
      color var(--code-block-color)
      padding 0
      background-color transparent
      border-radius 0
      .token
        &.comment,
        &.prolog,
        &.doctype,
        &.cdata
          color var(--code-token-comment)
        &.punctuation
          color var(--code-token-punctuation)
        &.property,
        &.tag,
        &.boolean,
        &.number,
        &.constant,
        &.symbol
          color var(--code-token-number)
        &.selector,
        &.attr-name,
        &.string,
        &.char,
        &.builtin
          color var(--code-token-string)
        &.operator,
        &.entity,
        &.url,
        &.variable
          color var(--code-token-operator)
        &.atrule,
        &.attr-value,
        &.keyword
          color var(--code-token-keyword)
        &.function,
        &.method
          color var(--code-token-function)
        &.class-name
          color var(--code-token-class)

div[class*="language-"]
  position relative
  background-color var(--code-block-bg)
  background-image linear-gradient(to right, var(--code-line-number-bg) 0, var(--code-line-number-bg) $lineNumbersWrapperWidth, transparent $lineNumbersWrapperWidth, transparent 100%)
  background-repeat no-repeat
  border-radius 6px
  font-size 13.6px
  box-shadow inset 0 0 0 1px var(--code-divider-color)
  .highlight-lines
    user-select none
    padding-top 1.3rem
    position absolute
    top 0
    left 0
    width 100%
    line-height 1.4
    .highlighted
      background-color var(--code-line-highlight)
      border-left 3px solid var(--code-line-highlight-border)
      box-sizing border-box
  pre, pre[class*="language-"]
    background transparent
    position relative
    z-index 1
  &::before
    position absolute
    z-index 3
    top 0.8em
    right 1em
    font-size 0.75rem
    color var(--code-lang-color)
  &:not(.line-numbers-mode)
    .line-numbers-wrapper
      display none
  &.line-numbers-mode
    .highlight-lines .highlighted
        position relative
        &:before
          content ' '
          position absolute
          z-index 3
          left 0
          top 0
          display block
          width $lineNumbersWrapperWidth
          height 100%
          background-color var(--code-line-highlight)
          border-left 3px solid var(--code-line-highlight-border)
          box-sizing border-box
    pre
      padding-left $lineNumbersWrapperWidth + 1 rem
      vertical-align middle
    .line-numbers-wrapper
      position absolute
      top 0
      width $lineNumbersWrapperWidth
      text-align center
      color var(--code-line-number-color)
      padding 1.25rem 0
      line-height 1.4
      br
        user-select none
      .line-number
        position relative
        z-index 4
        user-select none
        font-size 0.85em
    &::after
      content ''
      position absolute
      z-index 2
      top 1px
      left 1px
      width "calc(%s - 1px)" % $lineNumbersWrapperWidth
      height calc(100% - 7px)
      border-radius 5px 0 0 0
      background-color var(--code-block-bg)
      background-image linear-gradient(var(--code-line-number-bg), var(--code-line-number-bg))
      pointer-events none


for lang in $codeLang
  div{'[class~="language-' + lang + '"]'}
    &:before
      content ('' + lang)

div[class~="language-javascript"]
  &:before
    content "js"

div[class~="language-typescript"]
  &:before
    content "ts"

div[class~="language-markup"]
  &:before
    content "html"

div[class~="language-markdown"]
  &:before
    content "md"

div[class~="language-json"]:before
  content "json"

div[class~="language-ruby"]:before
  content "rb"

div[class~="language-python"]:before
  content "py"

div[class~="language-bash"]:before
  content "sh"

div[class~="language-php"]:before
  content "php"
