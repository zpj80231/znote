.znote-ad
  box-sizing border-box
  width 100%
  min-height 0
  border 1px solid var(--border-color)
  border-radius 4px
  background var(--background-color)
  overflow hidden
  a
    box-sizing border-box
    display flex
    flex-direction column
    gap .25rem
    width 100%
    padding .85rem 1rem
    color var(--text-color)
    text-decoration none
  .znote-ad-title
    font-size .95rem
    font-weight 600
  .znote-ad-desc
    color var(--text-color-sub)
    font-size .82rem
    line-height 1.45

.znote-ad-page-top
  a
    align-items center
    justify-content center
    text-align center

.znote-ad-sidebar
  a
    padding .7rem .8rem

.pin-adv
  box-sizing border-box
  width 100% !important
  min-height 0
  margin 0
  margin-top 5px
  border-radius 3px
  text-align center
  img
    display inline-block
    max-width 100%
    vertical-align middle

.pin-adv-sidebar
  margin-top 0

.html-module-slot
  .wwads-cn
    width 100% !important
    min-height 0
    margin 0
  .wwads-img img
    max-width 80px !important
  .wwads-text
    color var(--text-color)
    line-height 1.45
